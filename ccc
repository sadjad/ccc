#!/usr/bin/env bash
set -euo pipefail

VERSION="0.2.0"

usage() {
  local session_dir="${XDG_DATA_HOME:-$HOME/.local/share}/ccc"
  local config_file="${XDG_CONFIG_HOME:-$HOME/.config}/ccc/config"
  cat <<EOF
ccc - quick questions for Claude from your terminal

Usage:
  ccc [options] [prompt]
  command | ccc [options] [prompt]

If no prompt is given, ccc starts an interactive session.
Subsequent prompts automatically continue the conversation.

Options:
  -c, --continue       Continue the most recent conversation
  -f, --file <file>    Add file contents to the prompt (repeatable)
  -m, --model <model>  Model to use (default: opus)
  -s, --system <text>  Override the default system prompt
  --no-system          Use Claude Code's default system prompt instead
  -d, --dir <dir>      Add directory context for file access
  -n, --no-save        Don't save session (cannot be continued)
  -w, --write          Use multi-line editor for interactive input
  -y, --yank           Copy raw output to clipboard
  -h, --help           Show this help message
  -v, --version        Show version

Dependencies:
  claude               Required. https://claude.com/product/claude-code
  gum                  Optional. Spinner and multi-line input (brew install gum)
  glow                 Optional. Markdown rendering (brew install glow)

Config file:
  $config_file

  Supported keys:
    model=<model>       Default model (e.g. model=haiku)
    system=<text>       Default system prompt
    isolation=off       Disable session isolation (use default ~/.claude)

Sessions are isolated from regular Claude Code by setting
CLAUDE_CONFIG_DIR to $session_dir, so they don't appear
in your \`claude --resume\` list. Disable with isolation=off in config.

Examples:
  ccc "what is rust"
  ccc --model haiku "explain monads quickly"
  ccc --dir ./src "explain the architecture"
  ccc -f main.py "explain this"
  ccc -f src/auth.ts -f src/db.ts "how do these interact"
  git diff | ccc "review this diff"
  ccc --yank "write a bash one-liner to find large files"
  ccc --continue "can you elaborate on that last point"
  ccc                  Start an interactive session
EOF
}

# Check required dependencies
if ! command -v claude &>/dev/null; then
  echo "ccc: 'claude' is not installed." >&2
  echo "  Install Claude Code: https://claude.com/product/claude-code" >&2
  exit 1
fi

# Detect optional dependencies
has_gum=0; command -v gum &>/dev/null && has_gum=1
has_glow=0; command -v glow &>/dev/null && has_glow=1

# Defaults
model="opus"
continue_flag=()
add_dirs=()
file_data=""
system_prompt="Be concise and direct. Give short answers. Prefer examples and code over lengthy explanations. Use markdown formatting. Skip preamble."
copy=0
no_save=0
write_mode=0
stdin_data=""
isolation=1

# Config file
_ccc_config="${XDG_CONFIG_HOME:-$HOME/.config}/ccc/config"
if [[ -f "$_ccc_config" ]]; then
  while IFS='=' read -r key value; do
    [[ "$key" =~ ^#.*$ || -z "$key" ]] && continue
    key=$(echo "$key" | xargs)
    value=$(echo "$value" | xargs)
    case "$key" in
      model)     model="$value" ;;
      system)    system_prompt="$value" ;;
      isolation) [[ "$value" == "off" ]] && isolation=0 ;;
    esac
  done < "$_ccc_config"
fi

# Read stdin if piped
if [[ ! -t 0 ]]; then
  stdin_data=$(cat)
fi

# Parse flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    -c|--continue) continue_flag=(--continue); shift ;;
    -m|--model)    model="$2"; shift 2 ;;
    --model=*)     model="${1#*=}"; shift ;;
    -f|--file)     file_data+="$(cat "$2")"$'\n\n'; shift 2 ;;
    --file=*)      file_data+="$(cat "${1#*=}")"$'\n\n'; shift ;;
    -s|--system)   system_prompt="$2"; shift 2 ;;
    --system=*)    system_prompt="${1#*=}"; shift ;;
    --no-system)   system_prompt=""; shift ;;
    -d|--dir)      add_dirs+=(--add-dir "$2"); shift 2 ;;
    --dir=*)       add_dirs+=(--add-dir "${1#*=}"); shift ;;
    -n|--no-save)  no_save=1; shift ;;
    -w|--write)    write_mode=1; shift ;;
    -y|--yank)     copy=1; shift ;;
    -h|--help)     usage; exit 0 ;;
    -v|--version)  echo "ccc $VERSION"; exit 0 ;;
    --)            shift; break ;;
    *)             break ;;
  esac
done

# Isolate ccc sessions from regular `claude --resume` lists
if [[ "$isolation" -eq 1 ]]; then
  _ccc_data_dir="${XDG_DATA_HOME:-$HOME/.local/share}/ccc"
  export CLAUDE_CONFIG_DIR="$_ccc_data_dir"

  # First-run auth check (before mkdir so a fresh dir triggers it)
  if ! claude auth status 2>/dev/null | grep -q '"loggedIn": true'; then
    msg="**First-time setup**

ccc keeps its sessions **separate** from regular Claude Code so they don't
appear in your \`claude --resume\` list.

To do this, ccc needs a one-time authentication for its own config directory:

    $CLAUDE_CONFIG_DIR

You can disable this isolation by setting \`isolation=off\` in:

    $_ccc_config"

    if [[ "$has_gum" -eq 1 ]]; then
      rendered=$(echo "$msg" | gum format)
      gum style --border rounded --padding "1 2" --border-foreground 4 "$rendered"
      echo >&2
      choice=$(gum choose --header "What would you like to do?" \
        "Authenticate now" "Exit" "Disable isolation")
    else
      echo "$msg" >&2
      echo >&2
      echo "  1) Authenticate now" >&2
      echo "  2) Exit" >&2
      echo "  3) Disable isolation" >&2
      printf "Choose [1-3]: " >&2
      read -r answer </dev/tty
      case "$answer" in
        1) choice="Authenticate now" ;;
        3) choice="Disable isolation" ;;
        *) choice="Exit" ;;
      esac
    fi

    case "$choice" in
      "Authenticate now") mkdir -p "$_ccc_data_dir" && claude auth login ;;
      "Disable isolation")
        mkdir -p "$(dirname "$_ccc_config")"
        echo "isolation=off" >> "$_ccc_config"
        echo "Isolation disabled. Restart ccc to continue." >&2
        exit 0
        ;;
      *) exit 1 ;;
    esac
  fi

  mkdir -p "$_ccc_data_dir"
fi

_ccc_ads=(
  "git blame-someone-else — Finally, the accountability tool you deserve."
)

show_ad() {
  if [[ "$has_gum" -eq 1 && "${CCC_ADS:-}" == "1" ]]; then
    local ad="${_ccc_ads[$((RANDOM % ${#_ccc_ads[@]}))]}"
    local box
    box=$(gum style --border double --padding "0 2" --border-foreground 99 --foreground 213 "$ad")
    local sponsored
    sponsored=$(gum style --foreground 240 "Sponsored")
    printf '\n%s\n%s\n\n' "$box" "$sponsored" >&2
  fi
}

run_query() {
  local prompt="$1"
  local output
  local no_save_flag=()
  [[ "$no_save" -eq 1 ]] && no_save_flag=(--no-session-persistence)
  local system_flag=()
  [[ -n "$system_prompt" ]] && system_flag=(--system-prompt "$system_prompt")
  local claude_cmd=(claude --print --output-format=text --model "$model" \
    ${continue_flag[@]+"${continue_flag[@]}"} \
    ${add_dirs[@]+"${add_dirs[@]}"} \
    ${no_save_flag[@]+"${no_save_flag[@]}"} \
    ${system_flag[@]+"${system_flag[@]}"} \
    --allowedTools 'Read,Glob,Grep,Bash(ls:*),Bash(find:*),Bash(file:*),Bash(wc:*),Bash(head:*),Bash(tail:*),Bash(cat:*),Bash(git:*)' \
    -- "$prompt")

  show_ad

  if [[ "$has_gum" -eq 1 ]]; then
    output=$(gum spin --show-output --spinner dot --title "Thinking..." -- "${claude_cmd[@]}")
  else
    output=$("${claude_cmd[@]}")
  fi

  if [[ "$copy" -eq 1 ]]; then
    echo "$output" | pbcopy
  fi

  if [[ "$has_glow" -eq 1 ]]; then
    echo "$output" | PAGER='less -rFX' glow -w 0 -p
  else
    echo "$output"
  fi
}

# Interactive mode: loop with continuation
if [[ $# -eq 0 && -z "$stdin_data" && -z "$file_data" ]]; then
  if [[ ! -t 2 ]]; then
    usage >&2
    exit 1
  fi

  get_prompt() {
    if [[ "$has_gum" -eq 1 ]]; then
      if [[ "$write_mode" -eq 1 ]]; then
        gum write --header "ccc>" --header.foreground 240 --placeholder "Ask anything..." --char-limit 0 --show-help=false
      else
        gum input --placeholder "Ask anything..." --prompt "ccc> " --prompt.foreground 240 --char-limit 0 --show-help=false
      fi
    else
      read -r -p "ccc> " prompt </dev/tty && echo "$prompt"
    fi
  }

  prompt=$(get_prompt) || exit 0
  if [[ -z "$prompt" ]]; then
    exit 0
  fi

  [[ "$has_gum" -eq 1 ]] && gum style --background 236 --padding "0 1" "ccc> $prompt"
  run_query "$prompt"
  continue_flag=(--continue)

  while prompt=$(get_prompt); do
    [[ -z "$prompt" ]] && continue
    [[ "$has_gum" -eq 1 ]] && gum style --background 236 --padding "0 1" "ccc> $prompt"
    run_query "$prompt"
  done
  exit 0
fi

# Non-interactive: single query
prompt="$*"
context=""
[[ -n "$stdin_data" ]] && context+="$stdin_data"$'\n\n'
[[ -n "$file_data" ]] && context+="$file_data"
if [[ -n "$context" ]]; then
  if [[ -n "$prompt" ]]; then
    prompt="${context}${prompt}"
  else
    prompt="$context"
  fi
fi

run_query "$prompt"
